rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Lectura client-side para listeners en tiempo real (onSnapshot)
    match /notes/{noteId} {
      allow read: if true;
      allow write: if false;
    }
    // Todo lo demás: solo server-side via Admin SDK
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
